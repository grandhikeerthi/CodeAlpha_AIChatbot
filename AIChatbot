import java.util.Scanner;

public class AIChatbot {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.println("AI Chatbot Started");
        System.out.println("Type 'bye' to exit");

        while(true){

            System.out.print("You: ");
            String input = sc.nextLine();

            if(input.equalsIgnoreCase("hello")){
                System.out.println("Bot: Hi! Nice to meet you.");
            }
            else if(input.equalsIgnoreCase("java")){
                System.out.println("Bot: Java is a programming language.");
            }
            else if(input.equalsIgnoreCase("ai")){
                System.out.println("Bot: AI means Artificial Intelligence.");
            }
            else if(input.equalsIgnoreCase("bye")){
                System.out.println("Bot: Goodbye!");
                break;
            }
            else{
                System.out.println("Bot: Sorry, I don't understand.");
            }
        }

        sc.close();
    }
}
